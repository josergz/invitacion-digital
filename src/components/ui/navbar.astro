        </span>
      </a>

      <a href="#" class="group relative text-white transition">
        <span
          class="after:absolute after:-bottom-1 after:left-1/2 after:h-px after:w-0 after:-translate-x-1/2 after:bg-white after:transition-all after:duration-300 group-hover:after:w-full"
        >
          Features
        </span>
      </a>

      <a href="#" class="group relative text-white transition">
        <span
          class="after:absolute after:-bottom-1 after:left-1/2 after:h-px after:w-0 after:-translate-x-1/2 after:bg-white after:transition-all after:duration-300 group-hover:after:w-full"
        >
          Marketplace
        </span>
      </a>

      <a href="#" class="group relative text-white transition">
        <span
          class="after:absolute after:-bottom-1 after:left-1/2 after:h-px after:w-0 after:-translate-x-1/2 after:bg-white after:transition-all after:duration-300 group-hover:after:w-full"
        >
          Company
        </span>
      </a>
    </div>

    <!-- BOTON HAMBURGUESA -->
    <button
      id="menuButton"
      class="absolute right-6 p-2.5 text-white transition hover:scale-110 lg:hidden"
    >
      <span class="sr-only">Open main menu</span>

      <svg
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        class="size-7"
      >
        <path
          d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"
