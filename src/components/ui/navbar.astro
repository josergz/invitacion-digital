      <a href="#" class="group relative text-white transition">
        <span
          class="after:absolute after:-bottom-1 after:left-1/2 after:h-px after:w-0 after:-translate-x-1/2 after:bg-white after:transition-all after:duration-300 group-hover:after:w-full"
        >
